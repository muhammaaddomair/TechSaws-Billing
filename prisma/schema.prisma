generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum InvoiceType {
  DEVELOPMENT
  SUBSCRIPTION
  SERVICE
  HOSTING
  DOMAIN
  MAILBOX
  MAINTENANCE
  OTHER
}

enum InvoiceStatus {
  DRAFT
  GENERATED
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum BillingCycle {
  MONTHLY
  YEARLY
  ONE_TIME
  QUARTERLY
  CUSTOM
}

enum ClientType {
  SERVICE
  SAAS
  INFRA_ONLY
  HYBRID
  ONE_TIME_PROJECT
  RETAINER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  WATCH
  RISK
}

enum ContractStatus {
  ACTIVE
  PENDING
  EXPIRED
  NONE
}

enum UserRole {
  OWNER
  PARTNER
  STAFF
}

enum ProjectType {
  SOFTWARE_PRODUCT
  CLIENT_SERVICE
  INTERNAL_TOOL
  SUBSCRIPTION_SETUP
  INFRASTRUCTURE
  SUPPORT
  OTHER
}

enum ProjectStatus {
  NOT_STARTED
  PLANNING
  IN_PROGRESS
  ON_HOLD
  AWAITING_CLIENT
  UNDER_REVIEW
  DELIVERED
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MilestoneStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
  CANCELLED
}

enum RevenueCategory {
  PROJECT_SERVICE
  SUBSCRIPTION
  HOSTING_SERVER
  DOMAIN
  MAILBOX_EMAIL
  MAINTENANCE_SUPPORT
  OTHER_RECURRING
  OTHER_ONE_TIME
}

enum FinanceStatus {
  PLANNED
  RECOGNIZED
  PENDING
  CANCELLED
}

enum CostCategory {
  HOSTING_SERVER
  DOMAIN
  MAILBOX_EMAIL
  THIRD_PARTY_SOFTWARE
  CONTRACTOR_INTERNAL
  PAYMENT_FEES
  OTHER_OPERATIONAL
}

enum AssetType {
  DOMAIN
  VPS_SERVER
  CLOUD_HOSTING
  MAILBOX_EMAIL
  SAAS_SUBSCRIPTION
  SSL
  MAINTENANCE_SUPPORT
  OTHER_RECURRING_SERVICE
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  EXPIRING
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  JAZZCASH
  EASYPAISA
  STRIPE_MANUAL
  PAYPAL_MANUAL
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum NoteEntityType {
  CLIENT
  PROJECT
  INVOICE
  PAYMENT
  ASSET
  TASK
}

enum ActivityEntityType {
  CLIENT
  PROJECT
  INVOICE
  PAYMENT
  ASSET
  TASK
  NOTE
  MILESTONE
  SETTINGS
}

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  ARCHIVED
  REACTIVATED
  STATUS_CHANGED
  PAYMENT_LOGGED
  RENEWED
  NOTE_ADDED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  permissions  String[] @default(["ALL"])
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedClients     Client[]      @relation("ClientOwner")
  assignedProjects Project[]     @relation("ProjectOwner")
  assignedTasks    Task[]        @relation("TaskAssignee")
  createdTasks     Task[]        @relation("TaskCreator")
  paymentsEntered  Payment[]     @relation("PaymentEnteredBy")
  notes            InternalNote[]
  activities       ActivityLog[]
}

model Client {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  companyName    String
  contactPerson  String?
  phone          String?
  type           ClientType     @default(SERVICE)
  status         ClientStatus   @default(ACTIVE)
  contractStatus ContractStatus @default(NONE)
  startDate      DateTime?
  tags           String[]       @default([])
  ownerId        String?
  archivedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  owner          User?          @relation("ClientOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
  subscriptions  Subscription[]
  projects       Project[]
  payments       Payment[]
  assets         Asset[]
  revenueRecords RevenueRecord[]
  costRecords    CostRecord[]
  tasks          Task[]

  @@index([type, status])
  @@index([ownerId])
}

model Invoice {
  id               String              @id @default(cuid())
  invoiceNumber    String              @unique @default(cuid())
  clientId         String
  projectId        String?
  type             InvoiceType
  totalAmount      Decimal             @db.Decimal(12, 2)
  taxAmount        Decimal             @db.Decimal(12, 2)
  discountAmount   Decimal             @default(0) @db.Decimal(12, 2)
  finalAmount      Decimal             @db.Decimal(12, 2)
  amountPaid       Decimal             @default(0) @db.Decimal(12, 2)
  balanceAmount    Decimal             @default(0) @db.Decimal(12, 2)
  projectCost      Decimal             @default(0) @db.Decimal(12, 2)
  advancePercent   Decimal?            @db.Decimal(5, 2)
  advanceAmount    Decimal             @default(0) @db.Decimal(12, 2)
  timeline         String?
  status           InvoiceStatus       @default(DRAFT)
  issueDate        DateTime            @default(now())
  dueDate          DateTime?
  sentAt           DateTime?
  cancelledAt      DateTime?
  notes            String?
  internalComments String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project          Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items            InvoiceItem[]
  allocations      PaymentAllocation[]

  @@index([clientId, type, status])
  @@index([projectId])
  @@index([dueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  title       String
  description String?
  category    RevenueCategory?
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  recurring   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Subscription {
  id           String       @id @default(cuid())
  clientId     String
  serviceName  String
  monthlyCost  Decimal      @db.Decimal(12, 2)
  billingCycle BillingCycle
  status       AssetStatus   @default(ACTIVE)
  nextRenewal  DateTime?
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Project {
  id                     String           @id @default(cuid())
  clientId               String
  name                   String
  type                   ProjectType      @default(CLIENT_SERVICE)
  description            String?
  scopeSummary           String?
  status                 ProjectStatus    @default(NOT_STARTED)
  priority               Priority         @default(MEDIUM)
  startDate              DateTime?
  deadline               DateTime?
  revisedDeadline        DateTime?
  deliveryDate           DateTime?
  budgetAmount           Decimal          @default(0) @db.Decimal(12, 2)
  internalCostEstimate   Decimal          @default(0) @db.Decimal(12, 2)
  progress               Int              @default(0)
  assignedOwnerId        String?
  blockers               String?
  revisionCount          Int              @default(0)
  scopeChangeCount       Int              @default(0)
  delayReason            String?
  internalResponsibility String?
  clientCausedDelay      Boolean          @default(false)
  penaltyNote            String?
  deductionAmount        Decimal          @default(0) @db.Decimal(12, 2)
  archivedAt             DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  client                 Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedOwner          User?            @relation("ProjectOwner", fields: [assignedOwnerId], references: [id], onDelete: SetNull)
  milestones             Milestone[]
  tasks                  Task[]
  invoices               Invoice[]
  revenueRecords         RevenueRecord[]
  costRecords            CostRecord[]
  revisions              RevisionEntry[]
  scopeChanges           ScopeChange[]

  @@index([clientId, status])
  @@index([deadline])
  @@index([assignedOwnerId])
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String
  title          String
  description    String?
  dueDate        DateTime?
  status         MilestoneStatus @default(TODO)
  completionDate DateTime?
  owner          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([dueDate])
}

model RevenueRecord {
  id             String          @id @default(cuid())
  clientId       String
  projectId      String?
  invoiceId      String?
  sourceType     RevenueCategory
  reference      String?
  frequency      BillingCycle    @default(ONE_TIME)
  amount         Decimal         @db.Decimal(12, 2)
  status         FinanceStatus   @default(RECOGNIZED)
  recognizedDate DateTime        @default(now())
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId, sourceType, status])
  @@index([recognizedDate])
}

model CostRecord {
  id               String       @id @default(cuid())
  clientId         String?
  projectId        String?
  assetId          String?
  costType         CostCategory
  amount           Decimal      @db.Decimal(12, 2)
  billingFrequency BillingCycle @default(ONE_TIME)
  vendor           String?
  incurredDate     DateTime     @default(now())
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  client           Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project          Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  asset            Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([clientId, costType])
  @@index([incurredDate])
}

model Payment {
  id              String              @id @default(cuid())
  clientId        String
  paymentDate     DateTime            @default(now())
  amountReceived  Decimal             @db.Decimal(12, 2)
  currency        String              @default("USD")
  method          PaymentMethod
  referenceNumber String?
  notes           String?
  enteredById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  client          Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enteredBy       User?               @relation("PaymentEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  allocations     PaymentAllocation[]

  @@index([clientId, paymentDate])
  @@index([method])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  invoiceId String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([paymentId, invoiceId])
  @@index([invoiceId])
}

model Asset {
  id                       String         @id @default(cuid())
  clientId                 String
  name                     String
  type                     AssetType
  provider                 String?
  providerAccountReference String?
  purchaseDate             DateTime?
  renewalDate              DateTime?
  billingFrequency         BillingCycle   @default(MONTHLY)
  internalCost             Decimal        @default(0) @db.Decimal(12, 2)
  clientCharge             Decimal        @default(0) @db.Decimal(12, 2)
  status                   AssetStatus    @default(ACTIVE)
  autoRenewal              Boolean        @default(false)
  alertDays                Int            @default(30)
  notes                    String?
  archivedAt               DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  client                   Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  renewals                 AssetRenewal[]
  costRecords              CostRecord[]

  @@index([clientId, type, status])
  @@index([renewalDate])
}

model AssetRenewal {
  id             String   @id @default(cuid())
  assetId        String
  dateRenewed    DateTime @default(now())
  newRenewalDate DateTime
  cost           Decimal  @default(0) @db.Decimal(12, 2)
  clientCharge   Decimal  @default(0) @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now())
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, dateRenewed])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  clientId    String?
  projectId   String?
  assigneeId  String?
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  client      Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy   User?      @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([dueDate])
  @@index([clientId])
  @@index([projectId])
}

model InternalNote {
  id         String         @id @default(cuid())
  entityType NoteEntityType
  entityId   String
  body       String
  authorId   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  author     User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([authorId])
}

model ActivityLog {
  id         String             @id @default(cuid())
  entityType ActivityEntityType
  entityId   String
  action     ActivityAction
  message    String
  actorId    String?
  metadata   Json?
  createdAt  DateTime           @default(now())
  actor      User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
}

model RevisionEntry {
  id        String   @id @default(cuid())
  projectId String
  title     String
  notes     String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ScopeChange {
  id             String        @id @default(cuid())
  projectId      String
  title          String
  description    String?
  timeImpactDays Int           @default(0)
  priceImpact    Decimal       @default(0) @db.Decimal(12, 2)
  approvalState  FinanceStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
